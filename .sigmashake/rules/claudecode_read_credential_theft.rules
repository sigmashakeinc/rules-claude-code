# claudecode_read_credential_theft.rules — Claude Code credential read protection.
# Technology: claudecode | Capability: read
# Covers: CVE-2026-21852 API credential theft, Anthropic key access,
# project config inspection, and session file auditing.

rule no-read-claude-credential-files {
  enabled true
  priority 100
  severity error
  DENY read
  IF path CONTAINS ".claude/credentials"
  OR path CONTAINS ".claude/auth"
  OR path REGEX "\\.claude/.*token"
  OR path REGEX "\\.claude/.*key"
  OR path REGEX "\\.claude/.*secret"
  MESSAGE "CVE-2026-21852: API credential theft via project configurations. Reading Claude Code credential files is blocked. Attackers embed malicious configs in project .claude/ directories that, when processed, read and exfiltrate API credentials. Access credentials only through the official CLI and environment variables."
}

rule no-read-anthropic-config {
  enabled true
  priority 95
  severity error
  DENY read
  IF path CONTAINS ".anthropic"
  OR path REGEX "anthropic.*config"
  OR path REGEX "anthropic.*credentials"
  OR path REGEX "\\.config/anthropic"
  MESSAGE "Anthropic credential storage access blocked. CVE-2026-21852 demonstrated API credential theft through project config manipulation. Reading Anthropic config directories outside the official CLI is blocked. Use environment variables: ANTHROPIC_API_KEY."
}

rule ask-read-claude-project-config {
  enabled true
  priority 80
  severity warning
  ASK read
  IF path REGEX "\\.claude/(settings|config|commands|hooks)"
  OR path ENDS_WITH "CLAUDE.md"
  OR path ENDS_WITH ".clauderc"
  MESSAGE "Claude Code project config read. Malicious project configs are a documented RCE vector (CVE-2025-59536). Verify this file originates from a trusted source before the agent processes its contents."
  PROMPT "Is this project config from a trusted repository? Cloned repos may contain malicious .claude/ configs that inject hooks, override safety settings, or exfiltrate API keys (CVE-2026-21852)."
}

rule log-claude-session-file-access {
  enabled true
  priority 60
  severity info
  LOG read
  IF path REGEX "\\.claude/.*\\.json"
  OR path REGEX "\\.claude/.*\\.md"
  OR path REGEX "\\.claude/sessions"
  MESSAGE "Claude Code session or config file accessed. Audit trail for CVE-2026-21852 detection. Session files may contain conversation history with sensitive project context."
}
